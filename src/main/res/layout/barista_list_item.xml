<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/card_all_rounded"
    android:layout_width="match_parent"
    android:layout_height="81dp"
    android:layout_marginBottom="20dp"
    android:gravity="center"
    android:elevation="50dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/barista_img"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/bg_primary_all_rounded_50"/>

    <LinearLayout
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="17.45dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/barista_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/order_specification_title"
            android:text="@string/default_barista_name"/>

        <TextView
            android:id="@+id/barista_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/order_specification_title"
            android:textSize="14sp"
            android:textColor="@color/grey_border"
            android:text="@string/top_barista"/>

    </LinearLayout>

    <ImageView
        android:id="@+id/barista_badge"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="34dp"
        android:background="@drawable/barista_badge_green"/>
</LinearLayout>