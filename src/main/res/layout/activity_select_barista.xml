<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/my_white_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="25dp"
        android:paddingTop="21dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/arrow_left"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:src="@drawable/arrow_left"/>

        <TextView
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:lineSpacingExtra="0sp"
            android:gravity="center_horizontal|top"
            android:textAppearance="@style/title"
            android:text="@string/coffee_lover_assemblage"/>

        <ImageView
            android:id="@+id/cart"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:src="@drawable/cart"/>

    </LinearLayout>

    <TextView
        android:id="@+id/select_barista_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_a_barista"
        android:textAppearance="@style/order_specification_title"
        android:layout_marginTop="28dp"
        android:layout_marginStart="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nav_bar"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/barista_rc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/select_barista_title"/>

</androidx.constraintlayout.widget.ConstraintLayout>